# ---------- Backend API ----------
# Where the standalone amakuru-backend Express server is running.
NEXT_PUBLIC_API_URL=your_backend_url

# ---------- Firebase (client — safe to expose, prefixed NEXT_PUBLIC_) ----------
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
NEXT_PUBLIC_FIREBASE_VAPID_KEY=your_vapid_key

# MongoDB, Firebase Admin, Cloudinary secrets, and JWT_SECRET all moved to
# amakuru-backend/.env.example — the frontend never touches them directly
# now that it talks to the backend over HTTP instead of hitting the DB.
